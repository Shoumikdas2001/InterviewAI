{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "MongoDB": {
    "ConnectionString": "YOUR_MONGODB_ATLAS_CONNECTION_STRING",
    "DatabaseName": "interviewai"
  },
  "Jwt": {
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MINIMUM_32_CHARACTERS_LONG",
    "Issuer": "InterviewAI",
    "Audience": "InterviewAI",
    "AccessTokenExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "30"
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-1.5-flash"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://your-frontend-url.onrender.com"
    ]
  },
  "AllowedHosts": "*"
}
